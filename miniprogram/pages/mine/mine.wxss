.mine-page {
  min-height: 100vh;
  padding-bottom: 132rpx;
  background: #fff9f4;
}

.mine-hero {
  position: relative;
  padding: 34rpx 36rpx 96rpx;
  background: linear-gradient(135deg, #ff5a00 0%, #ff7a1a 55%, #ff4200 100%);
  overflow: hidden;
}

.mine-hero::after {
  content: "";
  position: absolute;
  right: -100rpx;
  top: 60rpx;
  width: 420rpx;
  height: 280rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.22);
  border-radius: 50%;
  transform: rotate(-12deg);
  box-shadow: 0 18rpx 0 rgba(255, 255, 255, 0.06), 0 36rpx 0 rgba(255, 255, 255, 0.05), 0 54rpx 0 rgba(255, 255, 255, 0.04);
}

.profile-card {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  min-height: 176rpx;
  padding: 30rpx 28rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.72);
  border-radius: 28rpx;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.32), rgba(255, 255, 255, 0.16));
  box-shadow: 0 18rpx 40rpx rgba(108, 43, 0, 0.16);
}

.avatar {
  position: relative;
  width: 128rpx;
  height: 128rpx;
  margin-right: 26rpx;
  border: 4rpx solid #ffffff;
  border-radius: 50%;
  background: #fff7f0;
  overflow: hidden;
}

.avatar-head {
  position: absolute;
  left: 43rpx;
  top: 26rpx;
  width: 42rpx;
  height: 42rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #ffd6ba, #f7a777);
}

.avatar-body {
  position: absolute;
  left: 26rpx;
  bottom: 16rpx;
  width: 76rpx;
  height: 50rpx;
  border-radius: 50% 50% 28rpx 28rpx;
  background: linear-gradient(135deg, #ffd6ba, #f7a777);
}

.profile-info {
  flex: 1;
  color: #ffffff;
}

.user-name,
.company-name {
  display: block;
}

.user-name {
  font-size: 40rpx;
  font-weight: 900;
  line-height: 1.2;
}

.company-name {
  margin-top: 14rpx;
  font-size: 28rpx;
}

.user-badge {
  min-width: 140rpx;
  height: 58rpx;
  padding: 0 24rpx;
  border-radius: 34rpx;
  background: rgba(255, 255, 255, 0.86);
  color: #e84a00;
  font-size: 27rpx;
  font-weight: 700;
  line-height: 58rpx;
  text-align: center;
}

.stats-card {
  position: relative;
  z-index: 2;
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  margin: -56rpx 36rpx 28rpx;
  padding: 34rpx 0 30rpx;
  border-radius: 28rpx;
  background: #ffffff;
  box-shadow: 0 16rpx 42rpx rgba(108, 43, 0, 0.11);
}

.stat-item {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.stat-item:not(:last-child)::after {
  content: "";
  position: absolute;
  right: 0;
  top: 20rpx;
  width: 1rpx;
  height: 104rpx;
  background: #f1e1d5;
}

.stat-icon {
  position: relative;
  width: 48rpx;
  height: 48rpx;
  margin-bottom: 14rpx;
  color: #ff5a00;
}

.stat-icon::before,
.stat-icon::after {
  content: "";
  position: absolute;
  box-sizing: border-box;
}

.stat-order::before {
  left: 11rpx;
  top: 8rpx;
  width: 28rpx;
  height: 34rpx;
  border: 5rpx solid currentColor;
  border-radius: 6rpx;
}

.stat-order::after {
  left: 17rpx;
  top: 18rpx;
  width: 16rpx;
  height: 12rpx;
  border-top: 4rpx solid currentColor;
  border-bottom: 4rpx solid currentColor;
}

.stat-pay::before {
  left: 7rpx;
  top: 10rpx;
  width: 34rpx;
  height: 28rpx;
  border: 5rpx solid currentColor;
  border-radius: 7rpx;
}

.stat-pay::after {
  right: 5rpx;
  top: 20rpx;
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: currentColor;
}

.stat-box::before {
  left: 8rpx;
  top: 12rpx;
  width: 32rpx;
  height: 28rpx;
  border: 5rpx solid currentColor;
  border-top: 0;
  border-radius: 5rpx;
}

.stat-box::after {
  left: 8rpx;
  top: 8rpx;
  width: 32rpx;
  height: 12rpx;
  border: 5rpx solid currentColor;
  border-radius: 5rpx 5rpx 0 0;
}

.stat-service::before {
  left: 8rpx;
  top: 10rpx;
  width: 32rpx;
  height: 28rpx;
  border: 5rpx solid currentColor;
  border-radius: 50%;
}

.stat-service::after {
  left: 28rpx;
  top: 31rpx;
  width: 12rpx;
  height: 10rpx;
  border-right: 5rpx solid currentColor;
  border-bottom: 5rpx solid currentColor;
  transform: rotate(28deg);
}

.stat-value {
  color: #ff5a00;
  font-size: 44rpx;
  font-weight: 900;
  line-height: 1.1;
}

.stat-label {
  margin-top: 12rpx;
  color: #2b211c;
  font-size: 26rpx;
}

.menu-card {
  margin: 0 36rpx;
  padding: 18rpx 34rpx;
  border-radius: 28rpx;
  background: #ffffff;
  box-shadow: 0 16rpx 42rpx rgba(108, 43, 0, 0.08);
}

.menu-row {
  display: flex;
  align-items: center;
  min-height: 106rpx;
  border-bottom: 1rpx solid #f4eee8;
}

.menu-row:last-child {
  border-bottom: 0;
}

.menu-icon {
  position: relative;
  width: 52rpx;
  height: 52rpx;
  margin-right: 34rpx;
  border-radius: 50%;
  background: #fff2e8;
  color: #ff5a00;
}

.menu-icon::before,
.menu-icon::after {
  content: "";
  position: absolute;
  box-sizing: border-box;
}

.mi-wallet::before {
  left: 13rpx;
  top: 15rpx;
  width: 28rpx;
  height: 22rpx;
  border: 5rpx solid currentColor;
  border-radius: 6rpx;
}

.mi-wallet::after {
  right: 10rpx;
  top: 23rpx;
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: currentColor;
}

.mi-ledger::before,
.mi-invoice::before,
.mi-setting::before {
  left: 14rpx;
  top: 10rpx;
  width: 24rpx;
  height: 32rpx;
  border: 5rpx solid currentColor;
  border-radius: 5rpx;
}

.mi-ledger::after,
.mi-invoice::after {
  left: 20rpx;
  top: 20rpx;
  width: 12rpx;
  height: 10rpx;
  border-top: 4rpx solid currentColor;
  border-bottom: 4rpx solid currentColor;
}

.mi-address::before {
  left: 15rpx;
  top: 9rpx;
  width: 22rpx;
  height: 28rpx;
  border: 5rpx solid currentColor;
  border-radius: 50% 50% 50% 6rpx;
  transform: rotate(-45deg);
}

.mi-address::after {
  left: 23rpx;
  top: 17rpx;
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: currentColor;
}

.mi-after::before {
  left: 13rpx;
  top: 10rpx;
  width: 26rpx;
  height: 30rpx;
  border-radius: 8rpx 8rpx 16rpx 16rpx;
  background: currentColor;
}

.mi-after::after {
  left: 21rpx;
  top: 19rpx;
  width: 12rpx;
  height: 8rpx;
  border-left: 4rpx solid #fff2e8;
  border-bottom: 4rpx solid #fff2e8;
  transform: rotate(-45deg);
}

.mi-setting::after {
  left: 21rpx;
  top: 17rpx;
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  border: 4rpx solid #fff2e8;
}

.menu-label {
  flex: 1;
  color: #1f1f1f;
  font-size: 31rpx;
}

.menu-arrow {
  color: #777;
  font-size: 50rpx;
  line-height: 1;
}
