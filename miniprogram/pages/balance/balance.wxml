<view class="page balance-page">
  <view class="wallet-card">
    <view class="wallet-copy">
      <text class="wallet-label">账户余额（元）</text>
      <text class="wallet-amount">¥{{balanceText}}</text>
    </view>
    <view class="coin-art">
      <view class="coin-stack stack-a"></view>
      <view class="coin-stack stack-b"></view>
      <view class="coin-stack stack-c"></view>
      <view class="coin-front">¥</view>
    </view>
  </view>

  <view class="panel amount-panel">
    <text class="panel-title">充值金额</text>
    <view class="amount-grid">
      <view wx:for="{{amountOptions}}" wx:key="value" class="amount-cell {{selectedAmount === item.value && !isCustomAmount ? 'active' : ''}}" data-value="{{item.value}}" bindtap="chooseAmount">¥ {{item.label}}</view>
      <view class="amount-cell {{isCustomAmount ? 'active' : ''}}" bindtap="chooseCustom">其他金额</view>
    </view>
    <text class="panel-title custom-title">自定义金额</text>
    <view class="custom-input">
      <text>¥</text>
      <input type="digit" value="{{customAmount}}" placeholder="请输入金额" bindinput="onCustomInput" />
    </view>
  </view>

  <view class="panel tips-panel">
    <view class="tips-title">
      <view class="tips-icon"></view>
      <text>充值说明</text>
    </view>
    <text class="tip-line">• 充值金额可用于后续打样抵扣</text>
    <text class="tip-line">• 余额不支持提现</text>
    <text class="tip-line">• 如需发票请在发票中心填写信息</text>
  </view>

  <button class="pay-button" loading="{{loading}}" bindtap="recharge">微信支付　立即充值</button>

  <view class="bottom-nav">
    <view class="nav-item" bindtap="goHome"><view class="nav-icon icon-home"></view><text>首页</text></view>
    <view class="nav-item" bindtap="goQuote"><view class="nav-icon icon-quote"></view><text>报价</text></view>
    <view class="nav-item" bindtap="goOrder"><view class="nav-icon icon-order"></view><text>订单</text></view>
    <view class="nav-item" bindtap="goService"><view class="nav-icon icon-service"></view><text>客服</text></view>
    <view class="nav-item active" bindtap="goMine"><view class="nav-icon icon-mine"></view><text>我的</text></view>
  </view>
</view>
