.service-page {
  min-height: 100vh;
  padding-bottom: 132rpx;
  overflow-x: hidden;
  background: linear-gradient(180deg, #fff9f4 0%, #fff 74%);
}

.hero {
  position: relative;
  padding: 74rpx 24rpx 134rpx;
  border-bottom-left-radius: 42% 34rpx;
  border-bottom-right-radius: 42% 34rpx;
}

.hero-title {
  display: block;
  color: #ffffff;
  font-size: 42rpx;
  font-weight: 900;
  line-height: 58rpx;
  text-align: center;
}

.welcome-card {
  position: absolute;
  left: 24rpx;
  right: 24rpx;
  bottom: -88rpx;
  display: grid;
  grid-template-columns: 118rpx minmax(0, 1fr) 230rpx;
  align-items: center;
  gap: 20rpx;
  min-height: 180rpx;
  padding: 26rpx 24rpx;
  overflow: hidden;
  border: 1rpx solid rgba(255, 255, 255, 0.76);
  border-radius: 28rpx;
  background: radial-gradient(circle at 82% 50%, #fff0e1 0%, #ffffff 50%, #ffffff 100%);
  box-shadow: 0 18rpx 48rpx rgba(132, 63, 15, 0.18);
}

.brand-badge {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 108rpx;
  height: 108rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #ff4f00 0%, #ff7a1a 100%);
  color: #ffffff;
  box-shadow: 0 10rpx 28rpx rgba(255, 90, 0, 0.22);
}

.brand-en {
  font-size: 24rpx;
  font-weight: 900;
  line-height: 28rpx;
}

.brand-cn {
  margin-top: 2rpx;
  font-size: 20rpx;
  font-weight: 700;
}

.welcome-copy {
  min-width: 0;
}

.welcome-title {
  display: block;
  color: #1f1f1f;
  font-size: 32rpx;
  font-weight: 900;
  line-height: 42rpx;
}

.welcome-desc,
.welcome-time {
  display: block;
  color: #4a403a;
  font-size: 24rpx;
  line-height: 34rpx;
}

.welcome-desc {
  margin-top: 10rpx;
}

.welcome-time {
  margin-top: 5rpx;
  color: #666666;
}

.welcome-image {
  width: 234rpx;
  height: 150rpx;
}

.service-content {
  padding: 112rpx 24rpx 0;
}

.service-card,
.notice-card,
.chat-card {
  border: 1rpx solid #f1e6dd;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 16rpx 42rpx rgba(126, 69, 28, 0.08);
}

.service-card {
  padding: 26rpx;
}

.card-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 22rpx;
}

.card-title,
.contact-title {
  color: #1f1f1f;
  font-size: 32rpx;
  font-weight: 900;
  line-height: 42rpx;
}

.refresh-action {
  display: flex;
  align-items: center;
  gap: 8rpx;
  color: #8f7b6a;
  font-size: 22rpx;
}

.refresh-icon {
  color: #cdbdad;
  font-size: 26rpx;
}

.faq-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  column-gap: 20rpx;
  row-gap: 18rpx;
}

.faq-item {
  position: relative;
  display: grid;
  grid-template-columns: 72rpx minmax(0, 1fr) 20rpx;
  gap: 16rpx;
  align-items: center;
  min-height: 116rpx;
  padding: 8rpx 2rpx;
}

.faq-item.expanded {
  align-items: start;
  border-radius: 18rpx;
  background: #fff9f4;
}

.faq-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 66rpx;
  height: 66rpx;
  border-radius: 50%;
  background: #fff2e8;
  color: #ff5a00;
  font-size: 25rpx;
  font-weight: 900;
}

.faq-title {
  display: block;
  color: #2a211d;
  font-size: 25rpx;
  font-weight: 800;
  line-height: 34rpx;
}

.faq-desc,
.faq-answer {
  display: block;
  color: #666666;
  font-size: 22rpx;
  line-height: 32rpx;
}

.faq-desc {
  margin-top: 6rpx;
}

.faq-answer {
  margin-top: 8rpx;
  color: #8b6550;
}

.faq-arrow {
  color: #c2b5aa;
  font-size: 44rpx;
  line-height: 44rpx;
}

.notice-card {
  display: grid;
  grid-template-columns: 6rpx minmax(0, 1fr) 142rpx;
  align-items: center;
  gap: 18rpx;
  margin-top: 24rpx;
  padding: 24rpx;
  background: linear-gradient(135deg, #fff3e8 0%, #ffffff 100%);
}

.notice-line {
  width: 6rpx;
  height: 86rpx;
  border-radius: 999rpx;
  background: #ff5a00;
}

.notice-title,
.notice-desc {
  display: block;
}

.notice-title {
  color: #ff5a00;
  font-size: 25rpx;
  font-weight: 900;
  line-height: 34rpx;
}

.notice-desc {
  margin-top: 8rpx;
  color: #7b6c61;
  font-size: 22rpx;
  line-height: 32rpx;
}

.notice-button {
  height: 58rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #ff4f00 0%, #ff7a1a 100%);
  color: #ffffff;
  font-size: 23rpx;
  font-weight: 800;
  line-height: 58rpx;
}

.contact-card {
  margin-top: 24rpx;
}

.contact-head {
  text-align: center;
}

.contact-title,
.contact-sub {
  display: block;
}

.contact-sub {
  margin-top: 8rpx;
  color: #666666;
  font-size: 24rpx;
  line-height: 34rpx;
}

.contact-grid {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: 24rpx;
}

.contact-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 144rpx;
  padding: 16rpx 10rpx;
  border-radius: 16rpx;
  background: linear-gradient(180deg, #fff8f2 0%, #ffffff 100%);
}

.contact-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 54rpx;
  height: 54rpx;
  border-radius: 50%;
  color: #ff5a00;
  font-size: 24rpx;
  font-weight: 900;
}

.contact-icon.wechat {
  color: #07c160;
}

.contact-name {
  display: block;
  margin-top: 14rpx;
  color: #241d18;
  font-size: 24rpx;
  font-weight: 800;
  line-height: 30rpx;
}

.contact-desc {
  display: block;
  margin-top: 8rpx;
  color: #777777;
  font-size: 20rpx;
  line-height: 26rpx;
  text-align: center;
}

.chat-card {
  display: grid;
  grid-template-columns: 240rpx minmax(0, 1fr);
  gap: 18rpx;
  margin-top: 26rpx;
  padding: 16rpx;
}

.agent-list {
  overflow: hidden;
  border-radius: 18rpx;
  background: #fffaf6;
}

.agent-item {
  position: relative;
  display: grid;
  grid-template-columns: 58rpx minmax(0, 1fr);
  gap: 12rpx;
  min-height: 118rpx;
  padding: 18rpx 12rpx;
  border-bottom: 1rpx solid #f2e8df;
}

.agent-item.active {
  background: linear-gradient(90deg, #fff0e3 0%, #ffffff 100%);
}

.agent-avatar,
.message-avatar {
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: linear-gradient(135deg, #fff5ec 0%, #ffdcc3 100%);
  color: #d84b00;
  font-weight: 900;
}

.agent-avatar {
  width: 56rpx;
  height: 56rpx;
  font-size: 24rpx;
}

.agent-info {
  min-width: 0;
}

.agent-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.agent-name {
  color: #211915;
  font-size: 24rpx;
  font-weight: 900;
  line-height: 30rpx;
}

.agent-status {
  padding: 2rpx 8rpx;
  border-radius: 999rpx;
  background: #eeeeee;
  color: #999999;
  font-size: 18rpx;
  line-height: 22rpx;
}

.agent-status.online {
  background: #fff0e3;
  color: #ff5a00;
}

.agent-role,
.agent-message,
.agent-time {
  display: block;
  color: #777777;
  font-size: 19rpx;
  line-height: 27rpx;
}

.agent-message {
  margin-top: 4rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.agent-time {
  position: absolute;
  right: 12rpx;
  top: 20rpx;
  color: #b18367;
}

.chat-window {
  min-width: 0;
}

.chat-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 70rpx;
  padding: 0 8rpx 12rpx;
  border-bottom: 1rpx solid #f0e5dc;
}

.chat-name {
  color: #1f1f1f;
  font-size: 27rpx;
  font-weight: 900;
}

.chat-role {
  margin-left: 12rpx;
  color: #777777;
  font-size: 21rpx;
}

.online-mark {
  display: flex;
  align-items: center;
  gap: 8rpx;
  color: #666666;
  font-size: 20rpx;
}

.online-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #07c160;
}

.message-list {
  padding: 20rpx 8rpx 14rpx;
}

.message-row {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  margin-bottom: 18rpx;
}

.message-row.customer {
  justify-content: flex-end;
}

.message-avatar {
  width: 42rpx;
  height: 42rpx;
  flex: 0 0 auto;
  font-size: 20rpx;
}

.message-main {
  max-width: 78%;
}

.message-row.customer .message-main {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.message-bubble {
  display: block;
  padding: 16rpx 18rpx;
  border-radius: 12rpx;
  background: #ffffff;
  color: #2d251f;
  font-size: 22rpx;
  line-height: 34rpx;
  box-shadow: 0 8rpx 22rpx rgba(90, 56, 28, 0.07);
}

.message-row.customer .message-bubble {
  background: #ffe2cc;
}

.message-meta {
  display: flex;
  justify-content: flex-end;
  gap: 8rpx;
  margin-top: 6rpx;
  color: #aaa19a;
  font-size: 18rpx;
  line-height: 22rpx;
}

.typing-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.typing-bubble {
  display: flex;
  align-items: center;
  gap: 8rpx;
  width: 76rpx;
  height: 44rpx;
  padding-left: 18rpx;
  border-radius: 12rpx;
  background: #ffffff;
}

.typing-bubble text {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: #b4aaa2;
}

.chat-input-row {
  display: grid;
  grid-template-columns: 42rpx minmax(0, 1fr) 54rpx;
  align-items: center;
  gap: 10rpx;
  height: 64rpx;
  margin: 10rpx 4rpx 0;
  padding: 0 10rpx;
  border: 1rpx solid #eee2d8;
  border-radius: 999rpx;
  background: #ffffff;
}

.smile-icon {
  color: #928780;
  font-size: 30rpx;
  text-align: center;
}

.chat-input {
  width: 100%;
  height: 54rpx;
  color: #2b211c;
  font-size: 22rpx;
}

.input-placeholder {
  color: #b7aea8;
}

.plus-button {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #ff5a00;
  color: #ffffff;
  font-size: 34rpx;
  font-weight: 400;
  line-height: 46rpx;
}

.quick-actions {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 10rpx;
  margin-top: 14rpx;
  padding: 12rpx;
  border-radius: 16rpx;
  background: #fff8f2;
}

.quick-action {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  color: #7b6c61;
  font-size: 18rpx;
}

.quick-action text:first-child {
  color: #ff5a00;
  font-weight: 900;
}

@media (max-width: 380px) {
  .welcome-card {
    grid-template-columns: 96rpx minmax(0, 1fr) 180rpx;
    gap: 14rpx;
  }

  .welcome-image {
    width: 190rpx;
  }

  .faq-grid,
  .chat-card {
    grid-template-columns: 1fr;
  }

  .agent-list {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .agent-item {
    grid-template-columns: 1fr;
    text-align: center;
  }

  .agent-avatar {
    margin: 0 auto;
  }
}
