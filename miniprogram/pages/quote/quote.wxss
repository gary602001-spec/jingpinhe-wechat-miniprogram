.quote-page {
  height: 100vh;
  padding-bottom: 0;
  overflow: hidden;
  background: #fff9f4;
}

.quote-hero {
  position: relative;
  z-index: 2;
  height: 322rpx;
  padding: 62rpx 24rpx 0;
  background: linear-gradient(135deg, #ff4f00 0%, #ff5a00 52%, #ff7a1a 100%);
}

.quote-hero::after {
  content: "";
  position: absolute;
  right: -160rpx;
  top: -110rpx;
  width: 430rpx;
  height: 430rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.08);
}

.quote-title {
  position: relative;
  z-index: 1;
  display: block;
  color: #ffffff;
  font-size: 44rpx;
  font-weight: 900;
  line-height: 60rpx;
  text-align: center;
  letter-spacing: 0;
}

.quote-search {
  position: relative;
  z-index: 1;
  height: 78rpx;
  margin-top: 26rpx;
  padding: 0 28rpx;
  border: 0;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.98);
  box-shadow: 0 14rpx 30rpx rgba(120, 45, 0, 0.1);
}

.quote-search .search-icon {
  width: 34rpx;
  height: 34rpx;
  margin-right: 18rpx;
}

.quote-search .search-icon::before {
  width: 21rpx;
  height: 21rpx;
  border-width: 4rpx;
  border-color: #8f8f8f;
}

.quote-search .search-icon::after {
  left: 25rpx;
  top: 25rpx;
  width: 13rpx;
  height: 4rpx;
  background: #8f8f8f;
}

.search-input {
  flex: 1;
  height: 78rpx;
  color: #1f1f1f;
  font-size: 28rpx;
  line-height: 78rpx;
}

.search-placeholder {
  color: #999999;
}

.rule-strip {
  position: absolute;
  left: 24rpx;
  right: 24rpx;
  bottom: -46rpx;
  z-index: 2;
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 92rpx;
  padding: 0 24rpx;
  border: 1rpx solid rgba(255, 90, 0, 0.2);
  border-radius: 24rpx;
  background: rgba(255, 247, 240, 0.98);
  box-shadow: 0 16rpx 36rpx rgba(104, 54, 22, 0.1);
}

.rule-item {
  display: flex;
  align-items: center;
  min-width: 0;
  color: #bf3d10;
  font-size: 23rpx;
  font-weight: 700;
  line-height: 30rpx;
  white-space: nowrap;
}

.rule-icon {
  position: relative;
  width: 34rpx;
  height: 34rpx;
  flex: 0 0 34rpx;
  margin-right: 9rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #ff5a00 0%, #ff8a27 100%);
}

.rule-icon::before,
.rule-icon::after {
  content: "";
  position: absolute;
  box-sizing: border-box;
}

.rule-auto::before {
  left: 14rpx;
  top: 7rpx;
  width: 8rpx;
  height: 19rpx;
  border-radius: 3rpx;
  background: #ffffff;
  transform: skew(-18deg);
}

.rule-manual::before {
  left: 12rpx;
  top: 7rpx;
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: #ffffff;
}

.rule-manual::after {
  left: 8rpx;
  top: 20rpx;
  width: 18rpx;
  height: 9rpx;
  border-radius: 12rpx 12rpx 6rpx 6rpx;
  background: #ffffff;
}

.rule-paper::before,
.rule-paper::after {
  left: 8rpx;
  width: 18rpx;
  height: 7rpx;
  border: 3rpx solid #ffffff;
  border-top: 0;
  transform: skewY(-24deg);
}

.rule-paper::before {
  top: 8rpx;
}

.rule-paper::after {
  top: 18rpx;
}

.rule-divider {
  width: 1rpx;
  height: 34rpx;
  margin: 0 14rpx;
  background: rgba(255, 90, 0, 0.22);
}

.quote-panel {
  position: relative;
  z-index: 1;
  display: flex;
  height: calc(100vh - 322rpx - 104rpx + 46rpx);
  margin: 76rpx 18rpx 0;
  overflow: hidden;
  border: 1rpx solid #f1e6dd;
  border-radius: 28rpx;
  background: #ffffff;
  box-shadow: 0 16rpx 42rpx rgba(112, 64, 28, 0.08);
}

.side-menu {
  width: 176rpx;
  flex: 0 0 176rpx;
  padding: 22rpx 18rpx 24rpx;
  border-right: 1rpx solid #f1e6dd;
  background: linear-gradient(180deg, #fffdfb 0%, #ffffff 100%);
}

.side-item {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 96rpx;
  margin-bottom: 18rpx;
  padding: 14rpx 10rpx;
  border-radius: 18rpx;
  color: #1f1f1f;
  font-size: 28rpx;
  font-weight: 600;
  line-height: 34rpx;
  text-align: center;
}

.side-item.active {
  background: linear-gradient(135deg, #fff0e5 0%, #fff8f2 100%);
  color: #ff5a00;
  font-weight: 900;
  box-shadow: inset 0 0 0 1rpx rgba(255, 90, 0, 0.06);
}

.product-list {
  flex: 1;
  height: 100%;
  padding: 24rpx 22rpx 132rpx;
}

.product-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 22rpx;
}

.quote-card {
  min-height: 338rpx;
  padding: 18rpx 16rpx 20rpx;
  border: 1rpx solid #f1e6dd;
  border-radius: 22rpx;
  background: #ffffff;
  text-align: center;
  box-shadow: 0 12rpx 30rpx rgba(112, 64, 28, 0.06);
}

.quote-image-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 210rpx;
  overflow: hidden;
  border-radius: 16rpx;
  background: linear-gradient(180deg, #fff8f2 0%, #ffffff 100%);
}

.quote-product-image {
  width: 100%;
  height: 100%;
}

.quote-card-title {
  display: block;
  margin-top: 18rpx;
  color: #1f1f1f;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 40rpx;
}

.quote-tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 120rpx;
  height: 42rpx;
  margin-top: 9rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: #fff0e5;
  color: #ff5a00;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 42rpx;
}

.quote-tag.manual {
  background: #fff4eb;
  color: #e84a00;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 500rpx;
  color: #999999;
  text-align: center;
}

.empty-title {
  color: #1f1f1f;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 42rpx;
}

.empty-desc {
  margin-top: 10rpx;
  color: #888888;
  font-size: 24rpx;
  line-height: 34rpx;
}
