.ledger-page {
  min-height: 100vh;
  padding-bottom: 134rpx;
  background: #fff9f4;
}

.ledger-tabs {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  height: 96rpx;
  border-bottom: 1rpx solid #f1e6dd;
  background: #ffffff;
}

.ledger-tab {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #333;
  font-size: 34rpx;
  font-weight: 700;
}

.ledger-tab.active {
  color: #ff5a00;
}

.ledger-tab.active::after {
  content: "";
  position: absolute;
  left: 50%;
  bottom: 8rpx;
  width: 62rpx;
  height: 7rpx;
  border-radius: 6rpx;
  background: #ff5a00;
  transform: translateX(-50%);
}

.ledger-balance-card {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 280rpx;
  margin: 32rpx 30rpx 26rpx;
  padding: 46rpx 42rpx;
  border: 1rpx solid #f4d8c8;
  border-radius: 28rpx;
  background: linear-gradient(135deg, #fff8f0 0%, #ffe4d1 100%);
  box-shadow: 0 14rpx 34rpx rgba(255, 90, 0, 0.08);
  overflow: hidden;
}

.ledger-balance-card::after {
  content: "";
  position: absolute;
  right: -40rpx;
  top: -30rpx;
  width: 360rpx;
  height: 260rpx;
  border: 2rpx solid rgba(255,255,255,.5);
  border-radius: 50%;
  box-shadow: 0 22rpx 0 rgba(255,255,255,.2), 0 44rpx 0 rgba(255,255,255,.14);
}

.balance-label,
.balance-value {
  position: relative;
  z-index: 1;
  display: block;
}

.balance-label {
  color: #4a4a4a;
  font-size: 30rpx;
}

.balance-value {
  margin-top: 34rpx;
  color: #ff4d00;
  font-size: 72rpx;
  font-weight: 900;
}

.wallet-art {
  position: relative;
  z-index: 1;
  width: 180rpx;
  height: 156rpx;
}

.wallet-body {
  position: absolute;
  right: 10rpx;
  top: 30rpx;
  width: 128rpx;
  height: 94rpx;
  border-radius: 22rpx;
  background: linear-gradient(135deg, rgba(255,122,26,.22), rgba(255,90,0,.42));
  box-shadow: inset 0 0 0 4rpx rgba(255,255,255,.34);
}

.wallet-body::after {
  content: "";
  position: absolute;
  right: 0;
  top: 30rpx;
  width: 54rpx;
  height: 32rpx;
  border-radius: 18rpx 0 0 18rpx;
  background: rgba(255,255,255,.7);
}

.wallet-coin {
  position: absolute;
  left: 12rpx;
  top: 58rpx;
  width: 78rpx;
  height: 78rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #ffc63f, #ff9f1a);
  color: #fff5c4;
  font-size: 50rpx;
  font-weight: 900;
  line-height: 78rpx;
  text-align: center;
}

.ledger-list {
  padding: 0 30rpx;
}

.flow-card {
  display: flex;
  align-items: center;
  min-height: 144rpx;
  margin-bottom: 20rpx;
  padding: 24rpx;
  border: 1rpx solid #f3e5da;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 22rpx rgba(0, 0, 0, 0.03);
}

.flow-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 78rpx;
  height: 78rpx;
  margin-right: 26rpx;
  border-radius: 50%;
  color: #ffffff;
  font-size: 42rpx;
  font-weight: 900;
}

.flow-icon.income {
  background: linear-gradient(135deg, #7bd35c, #28a944);
}

.flow-icon.expense {
  background: linear-gradient(135deg, #ff7a1a, #ff4d00);
}

.flow-main {
  flex: 1;
}

.flow-title,
.flow-time,
.flow-money text {
  display: block;
}

.flow-title {
  color: #1f1f1f;
  font-size: 32rpx;
  font-weight: 800;
}

.flow-time {
  margin-top: 12rpx;
  color: #777;
  font-size: 25rpx;
}

.flow-money {
  min-width: 190rpx;
  text-align: right;
}

.money-income,
.money-expense {
  font-size: 32rpx;
  font-weight: 900;
}

.money-income {
  color: #2fa84f;
}

.money-expense {
  color: #ff4d00;
}

.flow-balance {
  margin-top: 10rpx;
  color: #777;
  font-size: 24rpx;
}

.flow-arrow {
  margin-left: 16rpx;
  color: #aaa;
  font-size: 48rpx;
}

.empty-card {
  margin: 40rpx 30rpx;
  padding: 70rpx 30rpx;
  border-radius: 24rpx;
  background: #fff;
  text-align: center;
}

.empty-icon {
  width: 80rpx;
  height: 80rpx;
  margin: 0 auto 22rpx;
  border: 5rpx solid #ffb07d;
  border-radius: 18rpx;
}

.empty-title {
  display: block;
  color: #1f1f1f;
  font-size: 30rpx;
  font-weight: 900;
}

.empty-desc {
  display: block;
  margin-top: 12rpx;
  color: #999;
  font-size: 24rpx;
}
