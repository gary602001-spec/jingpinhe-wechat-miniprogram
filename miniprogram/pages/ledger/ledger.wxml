<view class="page ledger-page">
  <view class="ledger-tabs">
    <view wx:for="{{tabs}}" wx:key="key" class="ledger-tab {{activeTab === item.key ? 'active' : ''}}" data-key="{{item.key}}" bindtap="switchTab">{{item.name}}</view>
  </view>

  <view class="ledger-balance-card">
    <view>
      <text class="balance-label">账户余额（元）</text>
      <text class="balance-value">¥{{balanceText}}</text>
    </view>
    <view class="wallet-art">
      <view class="wallet-body"></view>
      <view class="wallet-coin">¥</view>
    </view>
  </view>

  <view class="ledger-list" wx:if="{{filteredList.length}}">
    <view wx:for="{{filteredList}}" wx:key="id" class="flow-card" bindtap="tapRecord">
      <view class="flow-icon {{item.amount > 0 ? 'income' : 'expense'}}">
        <text>{{item.amount > 0 ? '↓' : '¥'}}</text>
      </view>
      <view class="flow-main">
        <text class="flow-title">{{item.title}}</text>
        <text class="flow-time">{{item.time}}</text>
      </view>
      <view class="flow-money">
        <text class="{{item.amount > 0 ? 'money-income' : 'money-expense'}}">{{item.amountText}}</text>
        <text class="flow-balance">余额：¥{{item.balanceText}}</text>
      </view>
      <text class="flow-arrow">›</text>
    </view>
  </view>

  <view class="empty-card" wx:else>
    <view class="empty-icon"></view>
    <text class="empty-title">暂无账务明细</text>
    <text class="empty-desc">充值、支付、退款后会在这里显示</text>
  </view>

  <view class="bottom-nav">
    <view class="nav-item" bindtap="goHome"><view class="nav-icon icon-home"></view><text>首页</text></view>
    <view class="nav-item" bindtap="goQuote"><view class="nav-icon icon-quote"></view><text>报价</text></view>
    <view class="nav-item" bindtap="goOrder"><view class="nav-icon icon-order"></view><text>订单</text></view>
    <view class="nav-item" bindtap="goService"><view class="nav-icon icon-service"></view><text>客服</text></view>
    <view class="nav-item active" bindtap="goMine"><view class="nav-icon icon-mine"></view><text>我的</text></view>
  </view>
</view>
