<view class="order-page">
  <view class="order-hero">
    <text class="order-title">订单列表</text>
  </view>

  <view class="status-tabs">
    <view
      wx:for="{{tabs}}"
      wx:key="key"
      class="status-tab {{item.activeClass}}"
      data-key="{{item.key}}"
      bindtap="switchTab"
    >
      <text>{{item.label}}</text>
    </view>
  </view>

  <view class="search-panel">
    <view class="order-search">
      <view class="search-icon"></view>
      <input placeholder="请输入订单号 / 产品名称" value="{{keyword}}" bindinput="onSearch" />
    </view>
    <view class="filter-entry" bindtap="openFilter">
      <text class="filter-icon"></text>
      <text>筛选</text>
    </view>
  </view>

  <scroll-view class="order-scroll" scroll-y enhanced show-scrollbar="{{false}}">
    <view class="order-list" wx:if="{{orders.length}}">
      <view
        wx:for="{{orders}}"
        wx:for-item="orderItem"
        wx:key="orderNo"
        class="order-card"
        data-order-no="{{orderItem.orderNo}}"
        bindtap="openDetail"
      >
        <view class="order-head">
          <text class="order-no">订单号：{{orderItem.orderNo}}</text>
          <view class="head-right">
            <text>下单时间：{{orderItem.createdAt}}</text>
            <text class="head-arrow">›</text>
          </view>
        </view>

        <view class="order-body">
          <image class="order-product-image" src="{{orderItem.productImage}}" mode="aspectFit"></image>
          <view class="order-info">
            <text class="product-name">{{orderItem.productName}}</text>
            <text class="info-line">尺寸：{{orderItem.sizeText}}</text>
            <text class="info-line">数量：{{orderItem.quantityText}}</text>
            <text class="info-line">工艺：{{orderItem.craftText}}</text>
            <text class="info-line">面纸：{{orderItem.paperText}}</text>
          </view>
          <view class="order-side">
            <text class="status-text {{orderItem.statusClass}}">{{orderItem.statusText}}</text>
            <text class="assist-text">{{orderItem.assistLabel}}</text>
            <text class="order-amount">{{orderItem.amountText}}</text>
            <text class="item-count">共{{orderItem.itemCount}}件</text>
          </view>
        </view>

        <view class="action-row">
          <button
            wx:for="{{orderItem.actions}}"
            wx:for-item="actionItem"
            wx:key="text"
            class="action-btn {{actionItem.type}}"
            data-action="{{actionItem.action}}"
            data-order-no="{{orderItem.orderNo}}"
            catchtap="handleAction"
          >{{actionItem.text}}</button>
        </view>
      </view>
    </view>

    <view wx:else class="empty-state">
      <view class="empty-illustration">
        <view></view>
      </view>
      <text class="empty-title">暂无相关订单</text>
      <text class="empty-desc">您可以先去选择盒型进行报价</text>
      <button class="empty-button" bindtap="goQuotePage">去报价</button>
    </view>
  </scroll-view>

  <view class="bottom-nav">
    <view class="nav-item" bindtap="goHome"><view class="nav-icon icon-home"></view><text>首页</text></view>
    <view class="nav-item" bindtap="goQuote"><view class="nav-icon icon-quote"></view><text>报价</text></view>
    <view class="nav-item active"><view class="nav-icon icon-order"></view><text>订单</text></view>
    <view class="nav-item" bindtap="goService"><view class="nav-icon icon-service"></view><text>客服</text></view>
    <view class="nav-item" bindtap="goMine"><view class="nav-icon icon-mine"></view><text>我的</text></view>
  </view>
</view>
