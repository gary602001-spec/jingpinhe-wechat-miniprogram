.home-page {
  position: relative;
  height: 100vh;
  overflow: hidden;
  background: #ffffff;
}

.home-top {
  height: 312rpx;
  padding-top: 84rpx;
  background: linear-gradient(135deg, #ff4f00 0%, #ff6500 54%, #ff7a00 100%);
  text-align: center;
}

.home-heading {
  display: block;
  color: #ffffff;
  font-size: 43rpx;
  font-weight: 900;
  line-height: 58rpx;
  letter-spacing: 0;
}

.home-subheading {
  display: block;
  margin-top: 16rpx;
  color: rgba(255, 255, 255, 0.94);
  font-size: 27rpx;
  font-weight: 500;
  line-height: 36rpx;
  letter-spacing: 0;
}

.home-content {
  display: flex;
  flex-direction: column;
  height: calc(100vh - 102rpx - 160rpx);
  margin-top: -160rpx;
  padding: 0 24rpx 14rpx;
  overflow: hidden;
}

.hero-swiper {
  width: 100%;
  height: 30.5%;
  min-height: 310rpx;
  max-height: 440rpx;
  flex: 0 0 30.5%;
  overflow: hidden;
  border-radius: 20rpx;
  background: #fff0e3;
  box-shadow: 0 18rpx 42rpx rgba(146, 69, 18, 0.13);
}

.hero-banner {
  display: block;
  width: 100%;
  height: 100%;
}

.feature-grid {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 18rpx;
  flex: 0 0 23.8%;
  min-height: 236rpx;
  margin-top: 24rpx;
}

.feature-card {
  display: flex;
  flex-direction: column;
  overflow: hidden;
  border-radius: 18rpx;
  text-align: center;
}

.feature-warm {
  background: linear-gradient(180deg, #fff1eb 0%, #fff9f5 100%);
}

.feature-cream {
  background: linear-gradient(180deg, #fff5e8 0%, #fffdf8 100%);
}

.feature-blue {
  background: linear-gradient(180deg, #ecf5ff 0%, #f8fcff 100%);
}

.feature-purple {
  background: linear-gradient(180deg, #f2efff 0%, #fcfbff 100%);
}

.feature-copy {
  display: flex;
  flex: 0 0 66rpx;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  padding-top: 15rpx;
}

.feature-title {
  display: block;
  color: #843018;
  font-size: 29rpx;
  font-weight: 900;
  line-height: 34rpx;
}

.feature-blue .feature-title,
.feature-purple .feature-title {
  color: #1b2e78;
}

.feature-desc {
  display: block;
  margin-top: 2rpx;
  color: #3c312b;
  font-size: 20rpx;
  line-height: 24rpx;
}

.feature-image {
  display: block;
  flex: 1 1 auto;
  width: 101%;
  min-height: 148rpx;
  margin: 1rpx auto 7rpx;
}

.recommend-head {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  flex: 0 0 94rpx;
  text-align: center;
}

.recommend-title {
  display: block;
  color: #17110e;
  font-size: 40rpx;
  font-weight: 900;
  line-height: 44rpx;
  letter-spacing: 0;
}

.recommend-sub {
  display: block;
  margin-top: 4rpx;
  color: #27201c;
  font-size: 20rpx;
  line-height: 24rpx;
}

.product-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  grid-template-rows: repeat(2, minmax(0, 1fr));
  flex: 1 1 auto;
  min-height: 0;
  gap: 20rpx;
  padding: 0 6rpx;
}

.product-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-height: 0;
  overflow: hidden;
  padding: 14rpx 12rpx 12rpx;
  border: 1rpx solid #eadbd0;
  border-radius: 18rpx;
  background: #ffffff;
  text-align: center;
}

.product-image {
  display: block;
  flex: 1 1 auto;
  width: 100%;
  min-height: 94rpx;
  margin: 0 auto;
}

.product-name {
  display: block;
  flex: 0 0 auto;
  margin-top: 8rpx;
  color: #201a16;
  font-size: 26rpx;
  font-weight: 700;
  line-height: 32rpx;
  white-space: nowrap;
}

.product-tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  align-self: center;
  min-width: 86rpx;
  height: 30rpx;
  flex: 0 0 auto;
  margin-top: 5rpx;
  padding: 0 12rpx;
  border-radius: 999rpx;
  background: #ffe6d6;
  color: #ff4f00;
  font-size: 20rpx;
  font-weight: 800;
  line-height: 30rpx;
}

.bottom-nav {
  height: 104rpx;
  padding-top: 6rpx;
  border-top: 1rpx solid #e9e9e9;
  background: #ffffff;
  box-shadow: 0 -2rpx 10rpx rgba(30, 24, 18, 0.04);
}

.nav-item {
  font-size: 21rpx;
}

.nav-item.active {
  color: #ff5a00;
}
