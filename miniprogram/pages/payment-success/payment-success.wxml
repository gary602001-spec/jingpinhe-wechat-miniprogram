<view class="page success-page">
  <view class="success-mark">✓</view>
  <text class="success-title">支付成功</text>
  <text class="success-desc">感谢您的支持，我们将尽快安排打样</text>

  <view class="card order-card">
    <view class="order-no">订单号　{{order.orderNo}}</view>
    <view class="product-row">
      <image src="{{order.quote.image}}" mode="aspectFill"></image>
      <view>
        <text class="name">{{order.quote.title}}</text>
        <text class="desc">{{order.quote.length}}*{{order.quote.width}}*{{order.quote.height}}mm | {{order.quote.qty}}个</text>
        <text class="desc">单价：{{order.quote.unitText}}</text>
        <text class="price">实付金额：{{order.quote.totalText}}</text>
      </view>
    </view>
    <view class="info-line"><text>下单时间</text><text>{{order.createdAt}}</text></view>
    <view class="info-line"><text>交期</text><text>{{order.quote.leadTime}}</text></view>
    <view class="info-line"><text>状态</text><text>{{order.status}}</text></view>
  </view>

  <view class="actions">
    <button class="orange-button" bindtap="goOrder">查看订单</button>
    <button class="outline-button" bindtap="goHome">返回首页</button>
  </view>

  <view class="bottom-nav">
    <view class="nav-item" bindtap="goHome"><view class="nav-icon icon-home"></view><text>首页</text></view>
    <view class="nav-item" bindtap="goQuote"><view class="nav-icon icon-quote"></view><text>报价</text></view>
    <view class="nav-item active" bindtap="goOrder"><view class="nav-icon icon-order"></view><text>订单</text></view>
    <view class="nav-item" bindtap="goService"><view class="nav-icon icon-service"></view><text>客服</text></view>
    <view class="nav-item" bindtap="goMine"><view class="nav-icon icon-mine"></view><text>我的</text></view>
  </view>
</view>
