.checkout-page {
  min-height: 100vh;
  padding-bottom: 250rpx;
  background: #fff9f4;
}

.top-hero {
  height: 250rpx;
  padding-top: 82rpx;
  background: linear-gradient(135deg, #ff4f00 0%, #ff6400 58%, #ff7a1a 100%);
  text-align: center;
}

.page-title {
  color: #ffffff;
  font-size: 42rpx;
  font-weight: 900;
  line-height: 58rpx;
}

.checkout-content {
  position: relative;
  z-index: 2;
  margin-top: -42rpx;
  padding: 0 24rpx;
}

.form-stage {
  margin-top: -96rpx;
}

.card {
  border-radius: 28rpx;
  background: #ffffff;
  box-shadow: 0 10rpx 30rpx rgba(120, 60, 20, 0.06);
}

.step-card {
  display: flex;
  align-items: center;
  height: 108rpx;
  padding: 0 34rpx;
}

.step-item {
  display: flex;
  align-items: center;
  gap: 10rpx;
  color: #8d8179;
  font-size: 24rpx;
  font-weight: 700;
  white-space: nowrap;
}

.step-dot {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 38rpx;
  height: 38rpx;
  border-radius: 50%;
  background: #d7cbc2;
  color: #ffffff;
  font-size: 22rpx;
}

.step-item.active {
  color: #1f1f1f;
}

.step-item.active .step-dot {
  background: #ff5a00;
}

.step-line {
  height: 0;
  flex: 1;
  margin: 0 13rpx;
  border-top: 3rpx dotted #d9cec6;
}

.quote-card {
  display: flex;
  align-items: center;
  min-height: 230rpx;
  margin-top: 20rpx;
  padding: 22rpx 24rpx;
}

.quote-image {
  width: 210rpx;
  height: 186rpx;
  flex: 0 0 210rpx;
  border-radius: 20rpx;
  background: linear-gradient(180deg, #fff5ee 0%, #fffdf8 100%);
}

.quote-info {
  min-width: 0;
  flex: 1;
  padding: 0 18rpx 0 24rpx;
}

.quote-name,
.section-heading,
.receiver,
.pay-name {
  color: #1f1f1f;
  font-weight: 900;
}

.quote-name {
  display: block;
  font-size: 34rpx;
  line-height: 44rpx;
}

.quote-line {
  display: block;
  margin-top: 7rpx;
  color: #5f5750;
  font-size: 25rpx;
  line-height: 34rpx;
}

.mini-pill {
  display: inline-flex;
  align-items: center;
  height: 42rpx;
  margin-top: 12rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  background: #fff2e8;
  color: #ff5a00;
  font-size: 24rpx;
  line-height: 42rpx;
}

.quote-price {
  width: 150rpx;
  text-align: right;
}

.price-main {
  display: block;
  color: #ff5a00;
  font-size: 38rpx;
  font-weight: 900;
  line-height: 48rpx;
}

.price-sub {
  display: block;
  margin-top: 10rpx;
  color: #8c8179;
  font-size: 23rpx;
  line-height: 30rpx;
}

.section-card {
  margin-top: 22rpx;
  padding: 24rpx 24rpx 8rpx;
}

.section-heading {
  display: block;
  margin-bottom: 18rpx;
  font-size: 32rpx;
  line-height: 44rpx;
}

.form-row {
  display: flex;
  align-items: center;
  min-height: 88rpx;
  border-bottom: 1rpx solid #f4eee8;
}

.form-row.last {
  border-bottom: 0;
}

.line-icon {
  position: relative;
  width: 42rpx;
  height: 42rpx;
  flex: 0 0 42rpx;
  margin-right: 10rpx;
  color: #77716b;
}

.line-icon::before {
  position: absolute;
  left: 0;
  top: 0;
  width: 42rpx;
  height: 42rpx;
  font-size: 30rpx;
  line-height: 42rpx;
  text-align: center;
}

.user::before { content: "♙"; }
.phone::before { content: "▯"; }
.pin::before { content: "⌖"; }
.edit::before { content: "✎"; }
.calendar::before { content: "□"; }
.message::before { content: "○"; }
.invoice::before { content: "▤"; }
.invoice-title::before { content: "▧"; }
.tax::before { content: "※"; }

.field-label {
  width: 136rpx;
  flex: 0 0 136rpx;
  color: #2a2521;
  font-size: 27rpx;
}

.field-input {
  min-width: 0;
  flex: 1;
  height: 70rpx;
  color: #25211d;
  font-size: 26rpx;
}

.field-value {
  min-width: 0;
  flex: 1;
  color: #2b2622;
  font-size: 26rpx;
}

.placeholder,
.field-input,
.count,
.chevron {
  color: #999999;
}

.chevron {
  flex: 0 0 auto;
  padding-left: 12rpx;
  font-size: 46rpx;
  line-height: 46rpx;
}

.count {
  margin-left: 12rpx;
  font-size: 24rpx;
}

.segment {
  display: flex;
  flex: 1;
  height: 58rpx;
  border: 1rpx solid #eaded6;
  border-radius: 10rpx;
  overflow: hidden;
}

.segment-item {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 1;
  color: #4d4540;
  font-size: 24rpx;
}

.segment-item.active {
  border: 1rpx solid #ff5a00;
  background: #fff2e8;
  color: #ff5a00;
  font-weight: 700;
}

.agreement {
  display: flex;
  align-items: center;
  gap: 8rpx;
  height: 70rpx;
  padding: 0 14rpx;
  color: #5e5751;
  font-size: 26rpx;
}

.agree-dot {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 36rpx;
  height: 36rpx;
  border: 2rpx solid #d6ccc4;
  border-radius: 50%;
  color: transparent;
}

.agree-dot.checked {
  border-color: #ff5a00;
  background: #ff5a00;
  color: #ffffff;
}

.link,
.orange-link {
  color: #ff5a00;
}

.pay-stage {
  margin-top: -72rpx;
}

.pay-steps {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 112rpx;
  color: #ffffff;
}

.pay-step {
  display: flex;
  align-items: center;
  gap: 12rpx;
  color: rgba(255, 255, 255, 0.9);
  font-size: 27rpx;
  font-weight: 800;
}

.pay-step text:first-child {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.92);
  color: #ff5a00;
}

.pay-step.active text:first-child,
.pay-step.done text:first-child {
  background: #ffffff;
}

.pay-line {
  width: 54rpx;
  height: 2rpx;
  margin: 0 22rpx;
  background: rgba(255, 255, 255, 0.65);
}

.payment-card {
  margin-top: 20rpx;
  padding: 26rpx 28rpx;
}

.card-title-row,
.title-with-icon,
.selected-box,
.pay-method {
  display: flex;
  align-items: center;
}

.card-title-row {
  justify-content: space-between;
}

.title-with-icon {
  gap: 14rpx;
  color: #1f1f1f;
  font-size: 31rpx;
  font-weight: 900;
}

.card-title-only {
  margin-bottom: 20rpx;
}

.round-icon,
.select-check {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 42rpx;
  height: 42rpx;
  border-radius: 50%;
  background: #ff5a00;
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 800;
}

.pin-solid::before { content: "●"; }
.box-solid::before { content: "□"; }
.invoice-solid::before { content: "▤"; }
.note-solid::before { content: "≡"; }
.fee-solid::before { content: "¥"; }
.pay-solid::before { content: "✓"; }

.orange-link {
  font-size: 26rpx;
}

.selected-box {
  min-height: 120rpx;
  margin-top: 22rpx;
  padding: 18rpx 18rpx;
  border: 1rpx solid #ffd2b9;
  border-radius: 18rpx;
  background: #fffdfb;
}

.selected-address {
  display: flex;
  flex: 1;
  flex-direction: column;
  gap: 8rpx;
  min-width: 0;
  padding: 0 18rpx;
  color: #4a413b;
  font-size: 25rpx;
  line-height: 34rpx;
}

.receiver {
  margin-right: 36rpx;
  font-size: 29rpx;
}

.pay-product {
  position: relative;
  display: flex;
  gap: 20rpx;
  margin-top: 22rpx;
}

.pay-product image {
  width: 166rpx;
  height: 166rpx;
  flex: 0 0 166rpx;
  border-radius: 18rpx;
  background: #fff7f0;
}

.pay-product-info {
  flex: 1;
  min-width: 0;
  padding-right: 110rpx;
}

.pay-product-info text {
  display: block;
  margin-top: 9rpx;
  color: #625952;
  font-size: 25rpx;
  line-height: 32rpx;
}

.pay-name-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 6rpx;
}

.pay-name {
  font-size: 31rpx;
  line-height: 38rpx;
}

.quote-tag {
  display: inline-flex !important;
  margin-top: 0 !important;
  padding: 4rpx 12rpx;
  border: 1rpx solid #ffb28c;
  border-radius: 8rpx;
  color: #d95014 !important;
  font-size: 21rpx !important;
}

.pay-product-price {
  position: absolute;
  right: 0;
  top: 18rpx;
  color: #ff5a00;
  font-size: 31rpx;
  font-weight: 900;
}

.remark-box {
  width: 100%;
  height: 130rpx;
  padding: 20rpx;
  border: 1rpx solid #eaded6;
  border-radius: 16rpx;
  color: #2b2622;
  font-size: 25rpx;
}

.remark-count {
  display: block;
  margin-top: -34rpx;
  padding-right: 16rpx;
  color: #999999;
  font-size: 23rpx;
  text-align: right;
}

.fee-formula {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 22rpx;
}

.fee-node {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 132rpx;
  height: 112rpx;
  flex-direction: column;
  border-radius: 22rpx;
  background: #fff4ec;
  color: #6a5d55;
  font-size: 22rpx;
}

.fee-node text:last-child {
  margin-top: 8rpx;
  color: #1f1f1f;
  font-size: 25rpx;
  font-weight: 800;
}

.fee-node.strong {
  background: linear-gradient(135deg, #fff0e5 0%, #fff8f3 100%);
}

.fee-node.strong text:last-child {
  color: #ff5a00;
  font-size: 30rpx;
}

.symbol {
  color: #d4c7bd;
  font-size: 27rpx;
}

.fee-detail {
  margin-top: 18rpx;
  border-top: 1rpx solid #f4eee8;
}

.fee-detail view {
  display: flex;
  justify-content: space-between;
  padding-top: 14rpx;
  color: #6a625d;
  font-size: 25rpx;
}

.pay-method {
  min-height: 78rpx;
  border-bottom: 1rpx solid #f4eee8;
  color: #2b2622;
  font-size: 27rpx;
}

.pay-method.last {
  border-bottom: 0;
}

.wechat-mark,
.wallet-mark {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 42rpx;
  height: 42rpx;
  margin-right: 18rpx;
  border-radius: 50%;
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 800;
}

.wechat-mark { background: #11b85f; }
.wallet-mark { background: #ff5a00; }

.radio {
  position: relative;
  width: 34rpx;
  height: 34rpx;
  margin-left: auto;
  border: 2rpx solid #cfc6bf;
  border-radius: 50%;
}

.radio.checked {
  border-color: #ff5a00;
  background: #ff5a00;
}

.radio.checked::after {
  content: "✓";
  position: absolute;
  left: 0;
  top: 0;
  width: 34rpx;
  height: 34rpx;
  color: #ffffff;
  font-size: 22rpx;
  line-height: 34rpx;
  text-align: center;
}

.payment-agreement {
  margin: 16rpx 0 10rpx;
}

.fixed-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 104rpx;
  z-index: 55;
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 126rpx;
  padding: 18rpx 28rpx;
  border-top: 1rpx solid #eee6df;
  background: #ffffff;
  box-shadow: 0 -8rpx 24rpx rgba(80, 48, 28, 0.06);
}

.amount-box {
  display: flex;
  flex-direction: column;
}

.amount-title {
  color: #2a2521;
  font-size: 25rpx;
  font-weight: 700;
}

.amount-price {
  margin-top: 4rpx;
  color: #ff5a00;
  font-size: 42rpx;
  font-weight: 900;
  line-height: 48rpx;
}

.amount-note {
  margin-top: 4rpx;
  color: #5e5751;
  font-size: 23rpx;
}

.bar-button {
  width: 270rpx;
  height: 84rpx;
  border-radius: 18rpx;
  background: linear-gradient(135deg, #ff6a00 0%, #ff3d00 100%);
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 84rpx;
}
